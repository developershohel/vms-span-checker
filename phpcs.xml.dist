<?xml version="1.0"?>
<ruleset name="VMS Span Checker">
	<description>WordPress coding standards and PHP compatibility for this plugin.</description>

	<file>.</file>
	<file>../vms-span-checker-pro</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/assets/*</exclude-pattern>

	<rule ref="WordPress"/>
	<rule ref="PHPCompatibilityWP"/>

	<config name="testVersion" value="7.4-"/>
</ruleset>
